# ===========================================
# Itihasa Bot - Backend Environment Variables
# ===========================================

# --- LLM ---
# Primary: "ollama" (local, free) | "grok" | "gemini"
PRIMARY_LLM=ollama
OLLAMA_MODEL=llama3.2

XAI_API_KEY=your_xai_grok_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# --- App ---
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://itihasa-bot.vercel.app

# --- RAG ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=6
