# ===========================================
# Itihasa Bot - Backend Environment Variables
# ===========================================

# --- LLM API Keys ---
XAI_API_KEY=your_xai_grok_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Primary LLM: "grok" or "gemini"
PRIMARY_LLM=grok

# --- Database (Render Postgres) ---
DATABASE_URL=postgresql://user:password@hostname:5432/itihasa

# --- App ---
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://itihasa-bot.vercel.app

# --- RAG ---
EMBEDDING_MODEL=models/text-embedding-004
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=6

# --- Optional ---
# OPENAI_API_KEY=...   # only if you want OpenAI embeddings as alternative
